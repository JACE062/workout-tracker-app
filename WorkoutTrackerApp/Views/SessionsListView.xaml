<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:WorkoutTrackerApp.ViewModels"
             xmlns:models="clr-namespace:WorkoutTracker.Data;assembly=WorkoutTracker.Data"
             x:Class="WorkoutTrackerApp.Views.SessionsListView"
             x:DataType="viewmodels:SessionsListViewModel"
             Title="SessionListView">
    <VerticalStackLayout>
        <HorizontalStackLayout>
            <Button
                x:Name="CreateSessionBtn"
                Text="Create New Session"
                Command="{Binding CreateSessionCommand}"
                HorizontalOptions="Fill" />
        </HorizontalStackLayout>
        
        <Grid RowDefinitions="Auto, *">

            <Label Grid.Row="0" 
                Text="Workout History" 
                FontSize="24" 
                FontAttributes="Bold" 
                Margin="15" />

            <CollectionView Grid.Row="1" 
                ItemsSource="{Binding UserSessions}"
                Margin="15,0,15,0">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Session">
                        <Frame Margin="0,0,0,10" Padding="15" CornerRadius="8" HasShadow="True">
                            <Frame.GestureRecognizers>

                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:SessionsListViewModel}}, Path=SessionTappedCommand}"
                                    CommandParameter="{Binding .}" />

                            </Frame.GestureRecognizers>

                            <Label Text="{Binding Title}" FontSize="18" VerticalOptions="Center"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="No sessions found." FontSize="18" HorizontalOptions="Center" />
                        <Label Text="Let's get a workout session started!" TextColor="Gray" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>
        </Grid>

    </VerticalStackLayout>
</ContentPage>