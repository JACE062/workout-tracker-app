<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutTrackerApp.AboutPage"
             Title="AboutPage">
    <VerticalStackLayout>
        <HorizontalStackLayout>
            <Image Source="dotnet_bot.png"
                   SemanticProperties.Description="The dot net bot waving hello!"
                   HeightRequest="64" />

            <Label FontSize="22" FontAttributes="Bold" Text="Workout Tracker App " VerticalOptions="End" />
            <Label FontSize="22" Text="v1.0" VerticalOptions="End" />
        </HorizontalStackLayout>
        
        <Label 
            Text="This app is meant to serve as a simple workout tracker for keeping a record of all your exercises. Track your progress to see how you have improved over time, or just look back to remember what you did last time, if it's been a while."
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>